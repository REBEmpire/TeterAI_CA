# Copy to .env.local and fill in values

# Firebase / Firestore (for real-time task queue)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=teterai-ca-prototype.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=teterai-ca-prototype
VITE_FIREBASE_STORAGE_BUCKET=teterai-ca-prototype.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Google OAuth (for sign-in button)
VITE_GOOGLE_CLIENT_ID=

# Allowed email domain (defaults to teter.com)
VITE_ALLOWED_EMAIL_DOMAIN=teter.com
